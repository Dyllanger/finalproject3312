@page
@model finalproject3312.Pages_Players.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Player</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Player.PlayerID" />
            <div class="form-group">
                <label asp-for="Player.Username" class="control-label"></label>
                <input asp-for="Player.Username" class="form-control" />
                <span asp-validation-for="Player.Username" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Player.Favorite" class="control-label"></label>
                <input asp-for="Player.Favorite" class="form-control" />
                <span asp-validation-for="Player.Favorite" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Player.KillCount" class="control-label"></label>
                <input asp-for="Player.KillCount" class="form-control" />
                <span asp-validation-for="Player.KillCount" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Player.RunDate" class="control-label"></label>
                <input asp-for="Player.RunDate" class="form-control" />
                <span asp-validation-for="Player.RunDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <div class="col-md-offset-2 col-md-10">
                    <table>
                        <tr>
                        @{
                            var check = "";
                            int cnt = 0;
                            foreach (var character in Model.Characters)
                            {
                                if (cnt % 2 == 0)
                                {
                                    @:</tr><tr>
                                }
                                check = "";
                                if (Model.Player.PlayerCharacters!.Any(pc => pc.CharacterID == character.CharacterID))
                                {
                                    check = "checked";
                                }
                                <td>
                                    <input class="form-check-input me-1" type="checkbox" name="selectedCharacters" id="@("check" + @character.CharacterID)" value="@character.CharacterID" @check>
                                    <label class="form-check-label" for="@("check" + @character.CharacterID)">@character.Name</label>
                                </td>
                                cnt++;
                            }
                            @:</tr>
                        }
                    </table>
                </div>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
